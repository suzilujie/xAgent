{
  "name": "@xagent/terminal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "xagent": "./bin/cli.ts"
  },
  "scripts": {
    "dev": "bun --watch bin/cli.ts",
    "build": "bun build ./src/main.tsx --outdir ./dist --target bun --external react-devtools-core",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@xagent/core": "workspace:*",
    "@xagent/shared": "workspace:*",
    "zustand": "^5.0.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "^1.2.0",
    "@types/react": "^18.3.0"
  }
}
